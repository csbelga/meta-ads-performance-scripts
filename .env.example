# Credenciais Meta Ads
# Gere um token de acesso de longa duracao em developers.facebook.com
META_ACCESS_TOKEN=seu_token_aqui
META_AD_ACCOUNT_ID=1234567890

# Configuracao de alerta
CPL_LIMIT_BRL=25.00
ALERT_EMAIL_TO=destinatario@exemplo.com

# SMTP para envio do alerta
# Para Gmail, gere uma senha de aplicativo em myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASSWORD=senha_de_aplicativo
